lse)}\n    },[])\n\n    function menuClassName() {\n        if (!menuWidth) {\n            if (menu) {\n                return 'menu mobile open'\n            }else{\n                return 'menu mobile'\n            }\n        }else{\n            return 'menu computer'\n        }\n    }\n    function menuClick() {\n            if (menu) {\n                setMenu(false)\n            }else{\n                setMenu(true)\n            }\n    }\n    return(\n        <main className=\"conteiner\">\n            <header className={menuClassName()} >  \n                <a onClick={()=>{menuClick()}}>\n                    <MenuHamburguer menuValue={menu}/>\n                </a>\n                <MenuBox navigation={(props)=>{setMenu(false);navigation(props)}}/>\n            </header>\n            <div className=\"box\">\n              {children}\n            </div>\n        </main>\n    )\n}\nexport default Menu\n",{"ruleId":"54","replacedBy":"55"},{"ruleId":"56","replacedBy":"57"},{"ruleId":"58","severity":1,"message":"59","line":3,"column":8,"nodeType":"60","messageId":"61","endLine":3,"endColumn":18},{"ruleId":"62","severity":1,"message":"63","line":20,"column":13,"nodeType":"64","endLine":20,"endColumn":58},{"ruleId":"62","severity":1,"message":"63","line":33,"column":13,"nodeType":"64","endLine":33,"endColumn":62},{"ruleId":"62","severity":1,"message":"63","line":46,"column":13,"nodeType":"64","endLine":46,"endColumn":57},{"ruleId":"62","severity":1,"message":"63","line":26,"column":13,"nodeType":"64","endLine":26,"endColumn":57},{"ruleId":"62","severity":1,"message":"63","line":30,"column":13,"nodeType":"64","endLine":30,"endColumn":57},{"ruleId":"62","severity":1,"message":"63","line":34,"column":13,"nodeType":"64","endLine":34,"endColumn":58},{"ruleId":"62","severity":1,"message":"63","line":38,"column":13,"nodeType":"64","endLine":38,"endColumn":57},{"ruleId":"62","severity":1,"message":"63","line":42,"column":13,"nodeType":"64","endLine":42,"endColumn":56},{"rule